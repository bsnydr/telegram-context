# Copy this file to ".env" (same folder) and fill in the values.
# Keep .env private: it holds your bot token. It is gitignored; never commit it.

# REQUIRED: bot token from @BotFather (looks like 1234567890:ABCdef...)
TELEGRAM_BOT_TOKEN=

# REQUIRED before the bot will accept messages: your numeric Telegram user ID.
# Leave blank for the very first run, start the bot, send it /id in Telegram to
# learn your ID, then paste it here and restart. Comma-separate to allow more
# than one person (e.g. 111111111,222222222).
TELEGRAM_ALLOWED_USER_IDS=

# OPTIONAL: everything below has a sensible default; uncomment to override.

# Seconds of silence before a batch of forwards is filed. Default 90.
# TELEGRAM_DEBOUNCE_SECONDS=90

# Where filed markdown bundles (and a media/ subfolder of screenshots) are written.
# Default: %USERPROFILE%\claude\context\feedback
# Point this at a OneDrive/Dropbox folder if you want bundles to sync.
# TELEGRAM_OUTPUT_DIR=C:\Users\you\claude\context\feedback

# Log file location. Default: <this folder>\logs\telegram-context.log
# TELEGRAM_LOG_PATH=C:\Users\you\telegram-context\telegram-context.log

# Filename prefix for each bundle: <timestamp>_<prefix>_<slug>.md. Default "feedback".
# TELEGRAM_FILE_PREFIX=feedback

# --- Live synthesis (optional) ---
# Requires Claude Code installed and signed in (the `claude` CLI on PATH). When on,
# every filed item is folded into a rolling SYNTHESIS.md in your output folder, and the
# bot replies in Telegram flagging duplicates / conflicts. Set to 0 to turn it off.
# TELEGRAM_SYNTHESIS=1

# Which model does the synthesis. Blank = your Claude Code default. e.g. opus | sonnet | haiku
# TELEGRAM_SYNTHESIS_MODEL=

# Path to the Claude Code CLI. The bot auto-detects it on PATH and in the usual install
# spots, but a background Scheduled Task may not inherit your PATH at logon, so for
# unattended use set the ABSOLUTE path here. Run `where claude` (cmd) to find it, e.g.
# TELEGRAM_CLAUDE_BIN=C:\Users\you\AppData\Roaming\npm\claude.cmd

# Max seconds to wait for one synthesis pass before giving up. Default 120.
# TELEGRAM_SYNTHESIS_TIMEOUT=120
